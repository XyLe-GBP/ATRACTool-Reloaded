<Window x:Class="ATRACTool_Reloaded.WindowATWSelectTarget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ATRACTool_Reloaded"
        mc:Ignorable="d"
        Title="Specify output method for WAVE files" Height="120" Width="650" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Loaded="Grid_Loaded">
        <Label x:Name="label_Output" Content="Output method:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="110"/>
        <ComboBox x:Name="combobox_Method" HorizontalAlignment="Left" Margin="125,12,0,0" VerticalAlignment="Top" Width="480" SelectionChanged="Combobox_Method_SelectionChanged"/>
        <Button x:Name="Button_OK" Content="OK" HorizontalAlignment="Left" Margin="480,39,0,0" VerticalAlignment="Top" RenderTransformOrigin="-4.351,-2.123" Width="60" IsDefault="True" Click="Button_OK_Click"/>
        <Button x:Name="Button_Cancel" Content="Cancel" HorizontalAlignment="Left" Margin="545,39,0,0" VerticalAlignment="Top" RenderTransformOrigin="-2.676,-0.661" Width="60" IsCancel="True" Click="Button_Cancel_Click"/>

    </Grid>
</Window>
