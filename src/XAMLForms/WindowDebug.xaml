<Window x:Class="ATRACTool_Reloaded.WindowDebug"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ATRACTool_Reloaded"
        mc:Ignorable="d"
        Title="WindowDebug" Height="570" Width="1024" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Icon="/Properties/ATRACTool.ico" Loaded="Window_Loaded" Closed="Window_Closed" Closing="Window_Closing">
    <Grid>
        <Label x:Name="label_Debug" Content="Debug mode is enabled." HorizontalAlignment="Left" VerticalAlignment="Top" Width="215" Height="31" FontSize="14" Margin="10,0,0,0"/>
        <TabControl Margin="0,31,0,0" Opacity="0.9">
            <TabControl.Background>
                <ImageBrush ImageSource="/Properties/IMG_1540.JPG" Opacity="0.5" Stretch="UniformToFill" />
            </TabControl.Background>
            <TabItem Header="Generals" Margin="-2,-2,-45,0">
                <Grid Background="#80E5E5E5" Opacity="0.8">
                    <Label Content="Main Instance:" HorizontalAlignment="Left" Margin="10,239,0,0" VerticalAlignment="Top" Width="112"/>
                    <Label x:Name="label_MainInstance" Content="Main_Instance" HorizontalAlignment="Left" Margin="97,239,0,0" VerticalAlignment="Top" Width="337"/>
                    <Label x:Name="label_Version" Content="ATRACTool-Rel v0.0.0.0 (build:2000-01-01)" HorizontalAlignment="Center" Margin="0,5,0,0" VerticalAlignment="Top" Width="998"/>
                    <GroupBox Header="Other Instances:" Margin="0,265,0,30">
                        <Border BorderThickness="1" Padding="6">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock x:Name="textBlock_SubInstances" TextWrapping="Wrap" TextTrimming="None"/>
                            </ScrollViewer>
                        </Border>
                    </GroupBox>
                    <GroupBox Header="DialogMessages:" Margin="0,36,0,256">
                        <Border BorderThickness="1" Padding="6" Height="201" Margin="-6,0,-6,0">
                            <RichTextBox x:Name="richText_Message" IsReadOnly="True" IsDocumentEnabled="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="#00E5E5E5" Margin="-2,-7,-2,40"/>
                        </Border>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="Options" Margin="45,-2,-92,0">
                <Grid Background="#80E5E5E5" Opacity="0.8">
                    <CheckBox x:Name="checkBox_DebugFunc" Content="Allow execution of debug functions" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" IsChecked="True"/>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
